{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid === $uid",
        "referrals": {
          ".read": "auth != null && auth.uid === $uid",
          ".write": "auth != null"
        }
      }
    },
    "referralCodes": {
      ".read": "auth != null",
      "$code": {
        ".write": "auth != null && !data.exists()"
      }
    },
    "families": {
      ".read": "auth != null",
      "$familyId": {
        ".write": "auth != null"
      }
    },
    "rooms": {
      "$roomId": {
        "messages": {
          ".read": "auth != null",
          ".indexOn": "createdAt",
          "$messageId": {
            ".write": "auth != null && newData.child('uid').val() === auth.uid && newData.child('text').val().length <= 300"
          }
        }
      }
    }
  }
}
